{%- liquid
  assign theme_settings = settings
  assign reward_enabled = true
  if theme_settings.free_gift_enabled == false
    assign reward_enabled = false
  endif

  assign currency_code = cart.currency.iso_code | default: shop.currency

  case currency_code
    when 'INR'
      assign tier1_threshold = theme_settings.tier1_threshold_inr | default: 82999
      assign tier2_threshold = theme_settings.tier2_threshold_inr | default: 124999
      assign tier3_threshold = theme_settings.tier3_threshold_inr | default: 165999
      assign currency_symbol = '₹'
    when 'EUR'
      assign tier1_threshold = theme_settings.tier1_threshold_eur | default: 899
      assign tier2_threshold = theme_settings.tier2_threshold_eur | default: 1349
      assign tier3_threshold = theme_settings.tier3_threshold_eur | default: 1799
      assign currency_symbol = '€'
    when 'GBP'
      assign tier1_threshold = theme_settings.tier1_threshold_gbp | default: 799
      assign tier2_threshold = theme_settings.tier2_threshold_gbp | default: 1199
      assign tier3_threshold = theme_settings.tier3_threshold_gbp | default: 1599
      assign currency_symbol = '£'
    when 'CAD'
      assign tier1_threshold = theme_settings.tier1_threshold_cad | default: 1349
      assign tier2_threshold = theme_settings.tier2_threshold_cad | default: 2029
      assign tier3_threshold = theme_settings.tier3_threshold_cad | default: 2699
      assign currency_symbol = 'CA$'
    when 'AUD'
      assign tier1_threshold = theme_settings.tier1_threshold_aud | default: 1499
      assign tier2_threshold = theme_settings.tier2_threshold_aud | default: 2249
      assign tier3_threshold = theme_settings.tier3_threshold_aud | default: 2999
      assign currency_symbol = 'AU$'
    when 'AED'
      assign tier1_threshold = theme_settings.tier1_threshold_aed | default: 3669
      assign tier2_threshold = theme_settings.tier2_threshold_aed | default: 5509
      assign tier3_threshold = theme_settings.tier3_threshold_aed | default: 7339
      assign currency_symbol = 'AED '
    else
      assign tier1_threshold = theme_settings.tier1_threshold_usd | default: 999
      assign tier2_threshold = theme_settings.tier2_threshold_usd | default: 1499
      assign tier3_threshold = theme_settings.tier3_threshold_usd | default: 1999
      assign currency_symbol = '$'
  endcase

  assign gift_product = theme_settings.gift_product
  assign gift_variant_tier1 = theme_settings.gift_variant_tier1 | default: '42928271982663'
  assign gift_variant_tier2 = theme_settings.gift_variant_tier2 | default: '42928272015431'
  assign gift_variant_tier3 = theme_settings.gift_variant_tier3 | default: '42928272048199'

  assign msg_tier1_progress = theme_settings.msg_tier1_progress | default: 'Spend {{ symbol }}{{ amount }} more to unlock FREE 0.50 CT Diamond'
  assign msg_tier1_unlocked = theme_settings.msg_tier1_unlocked | default: 'Congratulations! You unlocked a FREE 0.50 CT Diamond'
  assign msg_tier2_progress = theme_settings.msg_tier2_progress | default: 'Spend {{ symbol }}{{ amount }} more to unlock FREE 0.75 CT Diamond'
  assign msg_tier2_unlocked = theme_settings.msg_tier2_unlocked | default: 'Congratulations! You unlocked a FREE 0.75 CT Diamond'
  assign msg_tier3_progress = theme_settings.msg_tier3_progress | default: 'Spend {{ symbol }}{{ amount }} more to unlock FREE 1 CT Diamond + FREE Shipping'
  assign msg_tier3_unlocked = theme_settings.msg_tier3_unlocked | default: 'Congratulations! You unlocked FREE 1 CT Diamond + FREE Shipping'
  assign msg_free_shipping_unlocked = theme_settings.msg_free_shipping_unlocked | default: 'FREE Shipping Unlocked'
  assign msg_free_shipping_progress = theme_settings.msg_free_shipping_progress | default: 'Spend {{ symbol }}{{ amount }} more to unlock FREE Shipping'
-%}

<script>
  window.rewardSettings = {
    enabled: {{ reward_enabled | json }},
    currency: {{ currency_code | json }},
    currency_symbol: {{ currency_symbol | json }},
    gift_product_id: {{ gift_product.id | json }},
    tiers: {
      tier1: {
        threshold: {{ tier1_threshold | json }},
        variant_id: {{ gift_variant_tier1 | json }},
        label: '0.50 CT Diamond Gift'
      },
      tier2: {
        threshold: {{ tier2_threshold | json }},
        variant_id: {{ gift_variant_tier2 | json }},
        label: '0.75 CT Diamond Gift'
      },
      tier3: {
        threshold: {{ tier3_threshold | json }},
        variant_id: {{ gift_variant_tier3 | json }},
        label: '1 CT Diamond Gift'
      }
    },
    free_shipping_threshold: {{ tier3_threshold | json }},
    messages: {
      tier1_progress: {{ msg_tier1_progress | json }},
      tier1_unlocked: {{ msg_tier1_unlocked | json }},
      tier2_progress: {{ msg_tier2_progress | json }},
      tier2_unlocked: {{ msg_tier2_unlocked | json }},
      tier3_progress: {{ msg_tier3_progress | json }},
      tier3_unlocked: {{ msg_tier3_unlocked | json }},
      free_shipping_unlocked: {{ msg_free_shipping_unlocked | json }},
      free_shipping_progress: {{ msg_free_shipping_progress | json }}
    }
  };
</script>