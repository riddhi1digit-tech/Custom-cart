{%- liquid
  assign theme_settings = settings
  assign reward_enabled = true

  if theme_settings.free_gift_enabled == false
    assign reward_enabled = false
  endif

  # Get the current currency
  assign current_currency = cart.currency.iso_code
  assign shop_currency = shop.currency
  
  # Define base thresholds in USD
  assign tier1_threshold_usd = theme_settings.tier1_threshold | default: 999
  assign tier2_threshold_usd = theme_settings.tier2_threshold | default: 1499
  assign tier3_threshold_usd = theme_settings.tier3_threshold | default: 1999
  
  # Set currency conversion rates (updated rates)
  # You can update these rates as needed
  assign usd_to_inr = 83.00
  assign usd_to_eur = 0.92
  assign usd_to_gbp = 0.79
  
  # Convert thresholds based on currency
  if current_currency == "INR"
    assign tier1_threshold = tier1_threshold_usd | times: usd_to_inr
    assign tier2_threshold = tier2_threshold_usd | times: usd_to_inr
    assign tier3_threshold = tier3_threshold_usd | times: usd_to_inr
    assign currency_symbol = "₹"
    assign currency_code = "INR"
  elsif current_currency == "EUR"
    assign tier1_threshold = tier1_threshold_usd | times: usd_to_eur
    assign tier2_threshold = tier2_threshold_usd | times: usd_to_eur
    assign tier3_threshold = tier3_threshold_usd | times: usd_to_eur
    assign currency_symbol = "€"
    assign currency_code = "EUR"
  elsif current_currency == "GBP"
    assign tier1_threshold = tier1_threshold_usd | times: usd_to_gbp
    assign tier2_threshold = tier2_threshold_usd | times: usd_to_gbp
    assign tier3_threshold = tier3_threshold_usd | times: usd_to_gbp
    assign currency_symbol = "£"
    assign currency_code = "GBP"
  else
    # Default to USD
    assign tier1_threshold = tier1_threshold_usd
    assign tier2_threshold = tier2_threshold_usd
    assign tier3_threshold = tier3_threshold_usd
    assign currency_symbol = "$"
    assign currency_code = "USD"
  endif

  # Round thresholds to 2 decimal places
  assign tier1_threshold = tier1_threshold | round: 2
  assign tier2_threshold = tier2_threshold | round: 2
  assign tier3_threshold = tier3_threshold | round: 2

  # Gift variants
  assign gift_product = theme_settings.gift_product
  assign gift_variant_tier1 = theme_settings.gift_variant_tier1 | default: '42928271982663'
  assign gift_variant_tier2 = theme_settings.gift_variant_tier2 | default: '42928272015431'
  assign gift_variant_tier3 = theme_settings.gift_variant_tier3 | default: '42928272048199'
  
  # Calculate cart total
  assign cart_total_cents = 0
  assign gift_in_cart = false
  assign gift_tier_in_cart = 0

  for item in cart.items
    assign item_variant_id = item.variant.id | append: ''
    if item.properties._gift == 'true' or item.properties._gift_tier != blank or item_variant_id == gift_variant_tier1 or item_variant_id == gift_variant_tier2 or item_variant_id == gift_variant_tier3
      assign gift_in_cart = true
      if item_variant_id == gift_variant_tier1
        assign gift_tier_in_cart = 1
      elsif item_variant_id == gift_variant_tier2
        assign gift_tier_in_cart = 2
      elsif item_variant_id == gift_variant_tier3
        assign gift_tier_in_cart = 3
      endif
    else
      assign cart_total_cents = cart_total_cents | plus: item.final_line_price
    endif
  endfor

  # Get cart total in the shop's currency
  assign cart_total = cart_total_cents | times: 1.0 | divided_by: 100
  
  # Determine current tier
  assign current_tier = 0
  if cart_total >= tier3_threshold
    assign current_tier = 3
  elsif cart_total >= tier2_threshold
    assign current_tier = 2
  elsif cart_total >= tier1_threshold
    assign current_tier = 1
  endif

  # Calculate progress percentage (0-100%)
  if cart_total <= 0
    assign progress_percentage = 0
  elsif cart_total >= tier3_threshold
    assign progress_percentage = 100
  else
    assign progress_percentage = cart_total | times: 100.0 | divided_by: tier3_threshold
  endif

  if progress_percentage > 100
    assign progress_percentage = 100
  endif

  # Calculate remaining amounts
  assign remaining_tier1 = tier1_threshold | minus: cart_total
  if remaining_tier1 < 0
    assign remaining_tier1 = 0
  endif
  
  assign remaining_tier2 = tier2_threshold | minus: cart_total
  if remaining_tier2 < 0
    assign remaining_tier2 = 0
  endif
  
  assign remaining_tier3 = tier3_threshold | minus: cart_total
  if remaining_tier3 < 0
    assign remaining_tier3 = 0
  endif

  # Format currency for display
  assign currency_symbol = cart.currency.symbol
  if currency_symbol == blank
    if current_currency == "INR"
      assign currency_symbol = "₹"
    elsif current_currency == "EUR"
      assign currency_symbol = "€"
    elsif current_currency == "GBP"
      assign currency_symbol = "£"
    else
      assign currency_symbol = "$"
    endif
  endif
-%}

<script>
window.rewardSettings = {
  enabled: {{ reward_enabled | json }},
  gift_product_id: {{ gift_product.id | json }},
  currency: "{{ cart.currency.iso_code }}",
  currency_symbol: "{{ currency_symbol }}",
  currency_code: "{{ currency_code }}",
  shopCurrency: "{{ shop.currency }}",
  moneyFormat: {{ shop.money_format | json }},
  
  tiers: {
    tier1: {
      threshold: {{ tier1_threshold | times: 100 }},
      variant_id: {{ gift_variant_tier1 | json }},
      label: "0.50 CT Diamond Gift",
      display_threshold: "{{ tier1_threshold | round: 2 }}",
      display_amount: "{{ currency_symbol }}{{ tier1_threshold | round: 2 }}"
    },
    tier2: {
      threshold: {{ tier2_threshold | times: 100 }},
      variant_id: {{ gift_variant_tier2 | json }},
      label: "0.75 CT Diamond Gift",
      display_threshold: "{{ tier2_threshold | round: 2 }}",
      display_amount: "{{ currency_symbol }}{{ tier2_threshold | round: 2 }}"
    },
    tier3: {
      threshold: {{ tier3_threshold | times: 100 }},
      variant_id: {{ gift_variant_tier3 | json }},
      label: "1 CT Diamond Gift",
      display_threshold: "{{ tier3_threshold | round: 2 }}",
      display_amount: "{{ currency_symbol }}{{ tier3_threshold | round: 2 }}"
    }
  },
  
  free_shipping_threshold: {{ tier3_threshold | times: 100 }},
  
  current_cart_total: {{ cart_total_cents }},
  current_tier: {{ current_tier }},
  progress_percentage: {{ progress_percentage }},
  
  remaining: {
    tier1: {{ remaining_tier1 | times: 100 }},
    tier2: {{ remaining_tier2 | times: 100 }},
    tier3: {{ remaining_tier3 | times: 100 }}
  },
  
  messages: {
    tier1_progress: {{ theme_settings.msg_tier1_progress | default: 'Spend {{ amount }} more to unlock FREE 0.50 CT Diamond' | json }},
    tier1_unlocked: {{ theme_settings.msg_tier1_unlocked | default: 'Congratulations! You unlocked FREE 0.50 CT Diamond' | json }},
    tier2_progress: {{ theme_settings.msg_tier2_progress | default: 'Spend {{ amount }} more to unlock FREE 0.75 CT Diamond' | json }},
    tier2_unlocked: {{ theme_settings.msg_tier2_unlocked | default: 'Congratulations! You unlocked FREE 0.75 CT Diamond' | json }},
    tier3_progress: {{ theme_settings.msg_tier3_progress | default: 'Spend {{ amount }} more to unlock FREE 1 CT Diamond + FREE Shipping' | json }},
    tier3_unlocked: {{ theme_settings.msg_tier3_unlocked | default: 'Congratulations! You unlocked FREE 1 CT Diamond + FREE Shipping' | json }}
  }
};
</script>